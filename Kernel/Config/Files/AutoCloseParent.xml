<!-- Kernel/Config/Files/AutoCloseParent.xml -->
<otrs_config version="2.0" init="Application">
    <Setting Name="ParentAutoCloseState" Required="0" Valid="1">
        <Description>State used to close parent ticket automatically.</Description>
        <Navigation>Core::Ticket</Navigation>
        <Value>
            <Item ValueType="String">closed successful</Item>
        </Value>
    </Setting>

    <Setting Name="ParentAutoCloseLinkType" Required="0" Valid="1">
        <Description>Link type used for parent-child relation.</Description>
        <Navigation>Core::Ticket</Navigation>
        <Value>
            <Item ValueType="String">ParentChild</Item>
        </Value>
    </Setting>

    <Setting Name="Ticket::EventModulePost###900-AutoCloseParent" Required="0" Valid="1">
        <Description>Auto close parent ticket when all children are closed.</Description>
        <Navigation>Core::Event</Navigation>
        <Value>
            <Hash>
                <Item Key="Module">Kernel::System::Ticket::Event::CloseParentIfChildrenClosed</Item>
                <Item Key="Event">TicketStateUpdate</Item>
                <Item Key="Transaction">1</Item>
            </Hash>
        </Value>
    </Setting>
</otrs_config>
